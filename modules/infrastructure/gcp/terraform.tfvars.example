# Specify the prefix for the instance
prefix       = "suse-ai-gcp"

# Specify the project id to use
project_id = "gcp-tf"

# Specify the version of RKE2 to be installed
rke2_version = "v1.32.10+rke2r1" # Check RKE2 releases at - https://github.com/rancher/rke2/releases

# Specify the region and zone to deploy cloud resources
region = "us-west2"

zone   = "us-west2-b"

# Specify the OS disk size in GB:
os_disk_size = 150

# Specify whether a new SSH key pair needs to be created for the instance
create_ssh_key_pair = true

# Specifies the full path where the pre-generated SSH PRIVATE key is located (not generated by Terraform).
ssh_private_key_path = null

# Specifies the full path where the pre-generated SSH PUBLIC key is located (not generated by Terraform).
ssh_public_key_path = null

# Specify the name of Application Registry
registry_name = "dp.apps.rancher.io"

# Specify the name of the secret for accessing the registry
registry_secretname = "application-collection"

# Specify the username and password for accessing registry
registry_username = "null"
registry_password = "null"

# Set to true for 3-node HA cluster
ha_setup = false
